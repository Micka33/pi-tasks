{
  "name": "@micka33/pi-tasks",
  "version": "0.1.0",
  "description": "Persistent shared task lists for Pi agents and MCP clients.",
  "type": "module",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi",
    "mcp",
    "tasks",
    "agents",
    "task-management",
    "multi-agent",
    "coordination",
    "sqlite"
  ],
  "files": [
    "bin/pi-tasks-mcp.js",
    "dist",
    "docs/pi-tasks-preview.png",
    "pi-tasks.md",
    "README.md",
    "skills"
  ],
  "bin": {
    "pi-tasks-mcp": "bin/pi-tasks-mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "coverage": "node scripts/check-coverage.mjs",
    "ci": "npm run typecheck && npm run coverage",
    "mcp": "npm run build && node dist/src/mcp/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && npm run build:package",
    "build:package": "tsc -p tsconfig.package.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "24.12.3",
    "typebox": "^1.1.38",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "node": "24.15.0"
  },
  "pi": {
    "extensions": [
      "./dist/src/pi/index.js"
    ],
    "skills": [
      "./skills"
    ],
    "image": "https://raw.githubusercontent.com/Micka33/pi-tasks/main/docs/pi-tasks-preview.png"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Micka33/pi-tasks.git"
  },
  "bugs": {
    "url": "https://github.com/Micka33/pi-tasks/issues"
  },
  "homepage": "https://github.com/Micka33/pi-tasks#readme",
  "publishConfig": {
    "access": "public"
  }
}
